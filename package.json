{
    "name": "spicyswipe-extension",
    "version": "1.3.0",
    "description": "AI-Powered Tinder Automation Chrome Extension",
    "scripts": {
        "dev": "web-ext run --source-dir . --start-url https://tinder.com --browser-console",
        "build": "web-ext build --source-dir . --artifacts-dir dist",
        "lint": "web-ext lint --source-dir .",
        "serve": "npx http-server . -p 5173 -c-1"
    },
    "keywords": [
        "chrome-extension",
        "tinder",
        "ai",
        "automation"
    ],
    "author": "Soufienne Rahali",
    "license": "SEE LICENSE IN License",
    "devDependencies": {
        "http-server": "^14.1.1",
        "web-ext": "^7.11.0"
    }
}